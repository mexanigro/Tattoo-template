{
  "entities": {
    "Appointment": {
      "title": "Appointment",
      "description": "A scheduled appointment.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the appointment" },
        "customerName": { "type": "string", "description": "Legal name of the customer" },
        "customerEmail": { "type": "string", "format": "email", "description": "Contact email for notifications" },
        "customerPhone": { "type": "string", "description": "Contact phone number" },
        "serviceId": { "type": "string", "description": "ID of the service selected" },
        "staffId": { "type": "string", "description": "ID of the staff member selected" },
        "date": { "type": "string", "format": "date", "description": "The date of the appointment (YYYY-MM-DD)" },
        "time": { "type": "string", "description": "The time of the appointment (HH:mm)" },
        "duration": { "type": "number", "description": "Duration in minutes" },
        "status": { 
          "type": "string", 
          "enum": ["confirmed", "pending", "cancelled", "completed", "expired"],
          "description": "Current state of the appointment" 
        },
        "paymentStatus": { "type": "string", "description": "Payment resolution state" },
        "stripeSessionId": { "type": "string", "description": "Linked Stripe session identifier" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["customerName", "customerEmail", "serviceId", "staffId", "date", "time", "duration", "status"]
    },
    "StaffOverride": {
      "title": "Staff Override",
      "description": "Custom schedule overrides for specific personnel.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Staff member ID from siteConfig" },
        "blockedDates": { "type": "array", "items": { "type": "string" }, "description": "Dates when the staff member is unavailable" },
        "blockedSlots": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "date": { "type": "string" },
              "start": { "type": "string" },
              "end": { "type": "string" },
              "reason": { "type": "string" }
            }
          }
        }
      }
    }
  },
  "firestore": {
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Collection of all bookings."
    },
    "/staff_overrides/{staffId}": {
      "schema": "StaffOverride",
      "description": "Collection of schedule exceptions."
    }
  }
}
