# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Master Template Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in the values for your client deployment.
#   cp .env.example .env
#
# Keys marked [REQUIRED] will disable a feature if left blank.
# Keys marked [OPTIONAL] have safe fallback behaviour when empty.
#
# ⚠  Never commit your real `.env` file. It is listed in `.gitignore`.
# ─────────────────────────────────────────────────────────────────────────────


# ─── Application URL ─────────────────────────────────────────────────────────
# [OPTIONAL] Full URL where the app is hosted, including protocol.
# Used for Stripe redirect URLs and self-referential links.
# Defaults to http://localhost:3000 in development.
APP_URL=https://your-client-domain.com


# ─── AI Service (Google Gemini) ──────────────────────────────────────────────
# [REQUIRED for AI chat & style consultation features]
# Get your key at: https://aistudio.google.com/app/apikey
# If left empty, AI routes return HTTP 503 and the chatbot shows a friendly
# "service unavailable" message. The rest of the app works normally.
GEMINI_API_KEY=


# ─── Stripe Payments ─────────────────────────────────────────────────────────
# [REQUIRED for online payments]
# Get these from: https://dashboard.stripe.com/developers → API keys
#
# Secret key (server-only, never expose to the client):
STRIPE_SECRET_KEY=
#
# Publishable key (safe for the frontend, prefixed with VITE_ for Vite):
VITE_STRIPE_PUBLISHABLE_KEY=
#
# Webhook signing secret — used to verify Stripe events.
# Get from: Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
# If left empty, the /api/webhook endpoint returns HTTP 503.
STRIPE_WEBHOOK_SECRET=


# ─── Email Notifications (Resend) ────────────────────────────────────────────
# [REQUIRED to send email notifications]
# Get your key at: https://resend.com → API Keys
# If left empty, notifications are logged to the server console instead of
# being emailed. No errors are thrown.
EMAIL_PROVIDER_API_KEY=
#
# The "from" address shown on outgoing emails.
# Must match a verified domain in your Resend account.
# Defaults to Resend's sandbox address when empty (only works for your own inbox).
EMAIL_FROM_ADDRESS=notifications@yourdomain.com


# ─── Notification Recipients ─────────────────────────────────────────────────
# [REQUIRED for email delivery]
# The primary email address that receives all business notifications.
BUSINESS_OWNER_EMAIL=owner@example.com
#
# [OPTIONAL] Override recipients per notification type.
# Falls back to BUSINESS_OWNER_EMAIL when left empty.
BOOKING_NOTIFICATION_EMAIL=
CONTACT_NOTIFICATION_EMAIL=


# ─── Admin Panel Access ───────────────────────────────────────────────────────
# [REQUIRED to access the admin dashboard]
# The Google account email authorized to log in to the admin panel.
# Only one email is supported per deployment.
VITE_ADMIN_EMAIL=admin@yourdomain.com


# ─── Firebase (Database & Authentication) ────────────────────────────────────
# Firebase credentials are NOT stored in this file.
# They live in `firebase-applet-config.json` at the project root.
#
# When setting up a new client deployment:
#   1. Create a new Firebase project at https://console.firebase.google.com
#   2. Go to Project Settings → Your Apps → Web App → Firebase SDK Config
#   3. Replace the contents of `firebase-applet-config.json` with the new config
#
# If `firebase-applet-config.json` is missing or has empty required fields,
# the app logs a warning and disables database features gracefully.
